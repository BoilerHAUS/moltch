# copy to infra/environments/staging/.env.staging and fill values

# api
API_NODE_ENV=production
API_PORT=8080
API_HOST_PORT=8080
API_APP_NAME=moltch-api
# required for /ready in production
API_READY_TOKEN=replace-me

# web
WEB_PORT=3000
WEB_HOST_PORT=3000

# edge + tls (used with docker-compose.staging.edge.yml)
STAGING_WEB_DOMAIN=staging.example.com
ACME_EMAIL=ops@example.com
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443
