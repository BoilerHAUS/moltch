# copy to infra/environments/staging/.env.staging and fill values

# api
API_NODE_ENV=production
API_PORT=8080
API_HOST_PORT=8080
API_APP_NAME=moltch-api
# required for /ready in production
API_READY_TOKEN=replace-me

# web
WEB_PORT=3000
WEB_HOST_PORT=3000

# immutable image refs (used with docker-compose.staging.images.yml)
API_IMAGE_REF=ghcr.io/boilerhaus/moltch-api:gitsha-abc1234
WEB_IMAGE_REF=ghcr.io/boilerhaus/moltch-web:gitsha-abc1234
