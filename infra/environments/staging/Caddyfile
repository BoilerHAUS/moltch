{
  email {$ACME_EMAIL}
}

{$STAGING_WEB_DOMAIN} {
  encode zstd gzip

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-Frame-Options "SAMEORIGIN"
  }

  @api path /api/*
  handle_path @api {
    reverse_proxy api:8080
  }

  handle {
    reverse_proxy web:3000
  }
}
