{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boilerhaus.org/moltch/schemas/LAUNCH_GATE_EVIDENCE_PACKAGE_V1.schema.json",
  "title": "Launch Gate Evidence Package V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "generated_at_utc",
    "prepared_by",
    "scope_refs",
    "target_environment",
    "overall_result",
    "traceability",
    "ci",
    "runtime",
    "decision"
  ],
  "properties": {
    "package_id": { "type": "string", "minLength": 1 },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "prepared_by": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9][a-z0-9-]{1,31}$" },
    "scope_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "target_environment": {
      "type": "string",
      "enum": ["staging", "preprod", "prod-like"]
    },
    "overall_result": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issue", "pull_request", "commit_sha", "runbook_refs"],
      "properties": {
        "issue": { "type": "string", "format": "uri" },
        "pull_request": { "type": "string", "format": "uri" },
        "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "runbook_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_name", "run_url", "required_checks"],
      "properties": {
        "workflow_name": { "type": "string", "minLength": 1 },
        "run_url": { "type": "string", "format": "uri" },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "status", "evidence"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["pass", "fail"] },
              "evidence": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environment_snapshot", "smoke", "readiness"],
      "properties": {
        "environment_snapshot": { "type": "string", "minLength": 1 },
        "smoke": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "script_ref", "artifact_ref"],
          "properties": {
            "status": { "type": "string", "enum": ["pass", "fail"] },
            "script_ref": { "type": "string", "minLength": 1 },
            "artifact_ref": { "type": "string", "minLength": 1 }
          }
        },
        "readiness": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "endpoint_ref", "observed_at_utc"],
          "properties": {
            "status": { "type": "string", "enum": ["pass", "fail"] },
            "endpoint_ref": { "type": "string", "minLength": 1 },
            "observed_at_utc": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "reason_codes", "risks", "follow_ups", "approver"],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1,
          "allOf": [
            {
              "not": {
                "pattern": "(?i)\\b(todo|tbd)\\b"
              }
            }
          ]
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "follow_ups": {
          "type": "array",
          "items": { "type": "string" }
        },
        "approver": { "type": "string", "minLength": 1 }
      }
    }
  }
}
